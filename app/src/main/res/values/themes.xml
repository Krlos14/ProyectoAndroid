<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Tema normal -->
    <style name="Theme.AniTalks" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <!-- Splash nativa -->
    <style name="Theme.AniTalks.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/anitalks</item>
        <item name="windowSplashScreenIconBackgroundColor">@android:color/transparent</item>
        <item name="postSplashScreenTheme">@style/Theme.AniTalks</item>
    </style>
</resources>
